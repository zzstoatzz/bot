# Bluesky credentials
BLUESKY_HANDLE=your.handle.bsky.social
BLUESKY_PASSWORD=your-app-password

# LLM Provider (optional - falls back to placeholder responses)
# ANTHROPIC_API_KEY=your-api-key

# Google Search API (optional - for web search tool)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Bot configuration
BOT_NAME=phi  # Change this to whatever you want!
PERSONALITY_FILE=personalities/phi.md  # Path to personality markdown file

# Server configuration
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false